@model GiftVM
@{
    ViewData["Title"] = "Gift Details";
}

<div class="container py-5">
    <div class="row">
        <div class="col-md-6">
            <!-- Main Image Display -->
            <div class="main-image-container mb-4 border border-3 border-light rounded-4 shadow">
                <img id="mainImage" src="@Model.PrimaryImageUrl" alt="@Model.Title"
                     class="img-fluid w-100"
                     style="height: 400px; object-fit: cover; cursor: zoom-in;"
                     onclick="showCurrentImageInModal()">
            </div>

            <!-- Thumbnail Gallery -->
            <div class="thumbnail-gallery d-flex flex-wrap gap-3 p-3 bg-light rounded-3">
                @if (Model.ImageUrls != null && Model.ImageUrls.Any())
                {
                    // Show primary image first in thumbnails
                    <div class="thumbnail-item active">
                        <img src="@Model.PrimaryImageUrl"
                             class="img-thumbnail rounded-3"
                             style="height: 80px; width: 80px; object-fit: cover;"
                             onclick="changeMainImage('@Model.PrimaryImageUrl')">
                    </div>

                    // Show other images
                    foreach (var img in Model.ImageUrls.Where(i => i != Model.PrimaryImageUrl))
                    {
                        <div class="thumbnail-item">
                            <img src="@img"
                                 class="img-thumbnail rounded-3"
                                 style="height: 80px; width: 80px; object-fit: cover;"
                                 onclick="changeMainImage('@img')">
                        </div>
                    }
                }
            </div>
        </div>

        <div class="col-md-6">
            <h2 class="fw-bold">@Model.Title</h2>
            <p class="text-muted"><i class="bi bi-geo-alt"></i> @Model.Location</p>
            <div class="description-container mb-3 p-3 bg-light rounded-3" style="white-space: pre-line">
                @Model.Description
            </div>
            <span class="badge bg-primary fs-6">@Model.GiftStatus</span>

            <!-- User Information Section -->
            <div class="card mt-4 border-light shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="card-title mb-0"><i class="bi bi-person-lines-fill"></i> Contact Information</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <strong><i class="bi bi-person"></i> Donor:</strong>
                        <span class="ms-2">@Model.UserFullName</span>
                    </div>
                    <div class="mb-3">
                        <strong><i class="bi bi-envelope"></i> Email:</strong>
                        <a href="mailto:@Model.UserEmail" class="ms-2 text-decoration-none text-primary">
                            @Model.UserEmail
                        </a>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.UserPhoneNumber))
                    {
                        <div class="mb-3">
                            <strong><i class="bi bi-telephone"></i> Phone:</strong>
                            <a href="tel:@Model.UserPhoneNumber" class="ms-2 text-decoration-none text-primary">
                                @Model.UserPhoneNumber
                            </a>
                        </div>
                    }
                </div>
            </div>
            <div class="mt-4 d-flex gap-2 justify-content-end">
                <a href="@(Context.Request.Headers["Referer"].ToString())" class="btn btn-outline-primary"> <i class="bi bi-arrow-left"></i> Back
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Image Modal -->
<div class="modal fade" id="imageModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content bg-transparent border-0">
            <div class="modal-body p-0 text-center">
                <img id="modalImage" src="" class="img-fluid rounded-3 shadow-lg" style="max-height: 90vh;">
            </div>
            <button type="button" class="btn-close btn-close-white position-absolute top-0 end-0 m-3" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
    </div>
</div>

@section Styles {
    <style>
        /* Main image container */
        .main-image-container {
            overflow: hidden;
            transition: all 0.3s ease;
        }

        /* Thumbnail gallery styling */
        .thumbnail-item {
            transition: all 0.3s ease;
            border-radius: 0.5rem;
        }

            .thumbnail-item img {
                transition: all 0.3s ease;
                border: 2px solid #dee2e6;
            }

            .thumbnail-item:hover img {
                transform: scale(1.05);
                border-color: #0d6efd;
            }

            .thumbnail-item.active img {
                border: 2px solid #0d6efd;
                box-shadow: 0 0 0 3px rgba(13, 110, 253, 0.2);
            }

        /* Modal styling */
        #imageModal .modal-content {
            background: transparent;
        }

        /* Description container */
        .description-container {
            line-height: 1.8;
        }
    </style>
}

@section Scripts {
    <script>
        // Change main image when thumbnail is clicked
        function changeMainImage(newSrc) {
            const mainImg = document.getElementById('mainImage');

            // Add fade effect
            mainImg.style.opacity = 0;
            setTimeout(() => {
                mainImg.src = newSrc;
                mainImg.style.opacity = 1;

                // Update active thumbnail
                document.querySelectorAll('.thumbnail-item').forEach(item => {
                    item.classList.remove('active');
                    if (item.querySelector('img').src === newSrc ||
                        item.querySelector('img').src === newSrc + '?') {
                        item.classList.add('active');
                    }
                });
            }, 200);
        }

        // Show CURRENT main image in modal (not just original primary image)
        function showCurrentImageInModal() {
            const currentImageSrc = document.getElementById('mainImage').src;
            const modal = new bootstrap.Modal(document.getElementById('imageModal'));
            document.getElementById('modalImage').src = currentImageSrc;
            modal.show();
        }

        // Initialize first thumbnail as active
        document.addEventListener('DOMContentLoaded', function() {
            const activeThumb = document.querySelector('.thumbnail-item.active');
            if (!activeThumb && document.querySelector('.thumbnail-item')) {
                document.querySelector('.thumbnail-item').classList.add('active');
            }
        });
    </script>
}