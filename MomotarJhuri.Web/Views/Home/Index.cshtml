@{
    ViewData["Title"] = "Home Page";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-primary mb-3">Welcome to MomotarJhuri</h1>
        <p class="lead fs-4">Discover amazing features and services tailored for you</p>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body text-center p-4">
                    <i class="bi bi-people fs-1 text-primary mb-3"></i>
                    <h3 class="h4 mb-3">Community</h3>
                    <p>Join our growing community of users and connect with others.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body text-center p-4">
                    <i class="bi bi-shield-lock fs-1 text-primary mb-3"></i>
                    <h3 class="h4 mb-3">Security</h3>
                    <p>Your data is protected with our advanced security measures.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body text-center p-4">
                    <i class="bi bi-lightning-charge fs-1 text-primary mb-3"></i>
                    <h3 class="h4 mb-3">Fast Service</h3>
                    <p>Experience lightning-fast performance and responsive design.</p>
                </div>
            </div>
        </div>
    </div>

    <div class="text-center mt-5">
        <div class="d-inline-block border-top border-bottom py-3 px-4">
            <p class="mb-2">Ready to get started?</p>
            <a asp-controller="User" asp-action="Register" class="btn btn-primary btn-lg px-4 me-2">
                <i class="bi bi-person-plus me-1"></i> Register Now
            </a>
            <a asp-controller="User" asp-action="Login" class="btn btn-outline-primary btn-lg px-4">
                <i class="bi bi-box-arrow-in-right me-1"></i> Login
            </a>
        </div>

        <div class="mt-4">
            <p class="text-muted">
                Learn more about <a href="https://learn.microsoft.com/aspnet/core" class="text-decoration-none">building Web apps with ASP.NET Core</a>
            </p>
        </div>
    </div>
</div>