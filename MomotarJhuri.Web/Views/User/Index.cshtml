@model User

<div class="w-100 card border-0 p-4">
	<div class="card-header bg-success bg-gradient ml-0 py-3">
		<div class="row">
			<div class="col-12 text-center">
				<h2 class="text-white py-2">Login To MomotorJhuri</h2>
			</div>
		</div>
	</div>

	<div class="card-body border p-4">
		<form method="post" class="row">
			<div class="p-3"> 
				<div class="form-floating py-1 col-12">
					<input asp-for="Email" class="form-control border shadow" />
					<label asp-for="Email" class="ms-2"></label>
					<span asp-validation-for="Email" class="text-danger"></span>
				</div>
				<div class="form-floating py-1 col-12">
					<input asp-for="Password" class="form-control border shadow" />
					<label asp-for="Password" class="ms-2"></label>
					<span asp-validation-for="Password" class="text-danger"></span>
				</div>
				

				<div class="row pt-2">
					<div class="col-10">
						<div class="row">
							<div class="col-2">
								<button type="submit" class="btn btn-success w-100"><i class="bi bi-check-circle"></i> Login</button>
							</div>
							<div class="col-2">
								<a asp-controller="Home" asp-action="Index" class="btn btn-secondary w-100"><i class="bi bi-x-circle"></i> Cancel</a>
							</div>
						</div>
						
					</div>
					<div class="col-2">
						<a asp-controller="User" asp-action="SignUp" class="btn btn-secondary w-100">SignUp</a>
					</div>
				</div>
			</div>
		</form>
	</div>
</div>

	
