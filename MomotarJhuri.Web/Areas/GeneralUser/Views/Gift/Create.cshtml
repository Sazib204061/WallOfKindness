@using MomotarJhuri.Domain.Enums
@model GiftVM

@{
    ViewData["Title"] = "Add New Gift";
}

<div class="container mt-4">
    <h2>Add New Gift</h2>
    <hr />

    <form asp-action="Create" enctype="multipart/form-data" class="needs-validation" novalidate>
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <!-- Your existing form fields remain the same -->
        <div class="row">
            <div class="col-md-6">
                <div class="form-group mb-3">
                    <label asp-for="Title" class="form-label"></label>
                    <input asp-for="Title" class="form-control" />
                    @* <span asp-validation-for="Title" class="text-danger"></span> *@
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Location" class="form-label"></label>
                    <input asp-for="Location" class="form-control" />
                    @* <span asp-validation-for="Location" class="text-danger"></span> *@
                </div>
            </div>

            <div class="col-md-6">
                <div class="form-group mb-3">
                    <label asp-for="GiftStatus" class="form-label"></label>
                    <select asp-for="GiftStatus" asp-items="Html.GetEnumSelectList<GiftStatus>()"
                            class="form-select">
                        <option disabled selected value="">-- Select Status --</option>
                    </select>
                    @* <span asp-validation-for="GiftStatus" class="text-danger"></span> *@
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    @* <span asp-validation-for="Description" class="text-danger"></span> *@
                </div>
            </div>
        </div>

        <!-- Updated file upload section with preview -->
        <div class="form-group mb-3">
            <label class="form-label">Upload Images</label>
            <input id="fileInput" type="file" multiple accept="image/*" class="form-control" />
            <small class="text-muted">Select multiple images (JPEG, PNG)</small>

            <!-- Hidden field to store file data -->
            <input type="hidden" id="fileData" name="UploadedImages" />

            <!-- Preview container -->
            <div id="imagePreview" class="mt-3 row g-2"></div>

            @* <span asp-validation-for="UploadedImages" class="text-danger"></span> *@
        </div>

        <div class="form-group mt-4">
            <button type="submit" class="btn btn-primary">Create Gift</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Styles {
    <style>
        .preview-container {
            position: relative;
            width: 120px;
            height: 120px;
            margin: 5px;
        }

        .preview-image {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border: 1px solid #ddd;
            border-radius: 4px;
        }

        .remove-btn {
            position: absolute;
            top: -10px;
            right: -10px;
            width: 25px;
            height: 25px;
            border-radius: 50%;
            background: #dc3545;
            color: white;
            border: none;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            cursor: pointer;
            padding: 0;
        }

            .remove-btn:hover {
                background: #c82333;
            }
    </style>
}

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
            document.addEventListener('DOMContentLoaded', function() {
        const fileInput = document.getElementById('fileInput');
        const imagePreview = document.getElementById('imagePreview');
        const form = document.querySelector('form');
        let uploadedFiles = [];

        // Create a hidden container for actual file inputs
        const filesContainer = document.createElement('div');
        filesContainer.style.display = 'none';
        form.appendChild(filesContainer);

        // Handle file selection
        fileInput.addEventListener('change', function(event) {
            const files = event.target.files;

            // Clear previous previews and inputs
            imagePreview.innerHTML = '';
            filesContainer.innerHTML = '';
            uploadedFiles = [];

            for (let i = 0; i < files.length; i++) {
                const file = files[i];

                if (!file.type.startsWith('image/')) continue;

                const reader = new FileReader();
                const fileId = Date.now() + i;

                reader.onload = function(e) {
                    // Create preview element
                    const previewDiv = document.createElement('div');
                    previewDiv.className = 'col-md-2 preview-container';
                    previewDiv.dataset.fileId = fileId;

                    const img = document.createElement('img');
                    img.src = e.target.result;
                    img.className = 'preview-image';

                    const removeBtn = document.createElement('button');
                    removeBtn.className = 'remove-btn';
                    removeBtn.innerHTML = '×';
                    removeBtn.onclick = function() {
                        removeImage(fileId);
                    };

                    previewDiv.appendChild(img);
                    previewDiv.appendChild(removeBtn);
                    imagePreview.appendChild(previewDiv);

                    // Store file reference
                    uploadedFiles.push({
                        id: fileId,
                        file: file
                    });

                    // Create hidden file input for form submission
                    const fileInput = document.createElement('input');
                    fileInput.type = 'file';
                    fileInput.name = 'UploadedImages';
                    fileInput.style.display = 'none';

                    // Create a new FileList and add our file
                    const dataTransfer = new DataTransfer();
                    dataTransfer.items.add(file);
                    fileInput.files = dataTransfer.files;

                    filesContainer.appendChild(fileInput);
                };

                reader.readAsDataURL(file);
            }
        });

        // Remove image function
        function removeImage(fileId) {
            // Remove from DOM
            const element = document.querySelector(`[data-file-id="${fileId}"]`);
            if (element) element.remove();

            // Remove from array
            uploadedFiles = uploadedFiles.filter(file => file.id !== fileId);

            // Rebuild hidden file inputs
            filesContainer.innerHTML = '';
            uploadedFiles.forEach(file => {
                const fileInput = document.createElement('input');
                fileInput.type = 'file';
                fileInput.name = 'UploadedImages';
                fileInput.style.display = 'none';

                const dataTransfer = new DataTransfer();
                dataTransfer.items.add(file.file);
                fileInput.files = dataTransfer.files;

                filesContainer.appendChild(fileInput);
            });
        }

        // Form validation
        form.addEventListener('submit', function(event) {
            if (uploadedFiles.length === 0) {
                event.preventDefault();
                alert('Please upload at least one image');
                return;
            }

            if (!form.checkValidity()) {
                event.preventDefault();
                event.stopPropagation();
            }

            form.classList.add('was-validated');
        });
    });
    </script>
}